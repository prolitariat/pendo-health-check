{
  "manifest_version": 3,
  "name": "Pendo Health Check",
  "version": "2.0.0",
  "description": "Instant Pendo installation grade with prioritized diagnostics, one-click issue export, inline debugger, and live service status.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
